# ==========================================
# Configuración Principal del Servidor
# ==========================================
PORT=3000
BASE_URL=http://localhost:3000

# ==========================================
# Autenticación de Google (OAuth)
# ==========================================
GOOGLE_CLIENT_ID=tu_google_client_id_aqui
GOOGLE_CLIENT_SECRET=tu_google_client_secret_aqui

# ==========================================
# Almacenamiento de Archivos (Cloudinary)
# ==========================================
CLOUDINARY_CLOUD_NAME=tu_nombre_de_nube_aqui
CLOUDINARY_API_KEY=tu_api_key_aqui
CLOUDINARY_API_SECRET=tu_api_secret_aqui

# ==========================================
# Credenciales de Firebase Admin SDK
# ==========================================
# Nota: Puedes obtener estos valores generando una nueva clave privada 
# desde la consola de Firebase (Configuración del proyecto > Cuentas de servicio).
FIREBASE_PROJECT_ID=tu_project_id_aqui
FIREBASE_PRIVATE_KEY_ID=tu_private_key_id_aqui
FIREBASE_PRIVATE_KEY_BASE64=tu_private_key_en_formato_base64_aqui
FIREBASE_CLIENT_EMAIL=tu_client_email@tu-proyecto.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=tu_client_id_numerico_aqui
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/tu_client_email...
FIREBASE_UNIVERSE_DOMAIN=googleapis.com